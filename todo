/* === Weather widget · unified phone layout (Hiking + Skiing) === */
@media (max-width: 600px) {
  /* Contain width per widget (no page-level overflow hacks) */
  .wx {
    max-width: 100%;
    overflow-x: hidden;          /* blocks sideways page-pan from inner scrollers */
    box-sizing: border-box;
  }

  /* Current row: compact two-column */
  .wx-now {
    grid-template-columns: auto 1fr;
    gap: 8px 12px;
  }

  /* Hourly: scroll INSIDE the widget, with snap, no page pan */
  .wx-hours {
    /* neutralize panel padding so scroller can touch edges without forcing page width */
    margin-inline: -12px;
    padding-inline: 12px;
  }
  .wx-strip {
    display: flex !important;
    flex-wrap: nowrap !important;
    gap: 10px !important;
    overflow-x: auto !important;           /* you can swipe this row */
    overflow-y: hidden;
    -webkit-overflow-scrolling: touch;
    scroll-snap-type: x mandatory;
    overscroll-behavior-x: contain;        /* prevent page from panning */
  }
  .wx-hour {
    flex: 0 0 78px !important;             /* fixed tile width for readability */
    scroll-snap-align: start;
    text-align: center;
  }

  /* 7-day: readable single column */
  .wx-grid {
    grid-template-columns: 1fr !important; /* force one column on phones */
    gap: 10px !important;
  }
  .wx-day {
    display: grid;
    grid-template-columns: 1fr auto auto;  /* Day | Icon | Temps */
    align-items: center;
    column-gap: 10px;
    text-align: left;
    padding: 12px;
  }
  .wx-day .temps { white-space: nowrap; justify-self: end; }
  .wx-day .precip { grid-column: 1 / -1; margin-top: 2px; text-align: right; }
}

